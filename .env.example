# API server settings.
PORT=4000
NODE_ENV=development

# Basic API hardening defaults.
API_JSON_BODY_LIMIT=64kb
API_CHAT_RATE_LIMIT_MAX=30
API_CHAT_RATE_LIMIT_WINDOW_MS=60000

# Nanochat-inspired serving defaults.
NANOCHAT_TEMPERATURE=0.7
NANOCHAT_TOP_K=50
NANOCHAT_MAX_TOKENS=256

# Optional OpenRouter integration for a real hosted chat backend.
OPENROUTER_ENABLED=true
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# Optional Ollama integration for local runtime support.
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# Optional default provider selection.
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama3
